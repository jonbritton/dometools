#!/bin/bash
# make7th-job. — convert frames, then rsync. Safe for cron.
set -euo pipefail

SRC_FRAMES="$1"

# Derive LOCAL_OUT from SRC_FRAMES by stripping the trailing ".framenum.ext"
# components. Frame filenames consistently end with .NNNN.png / .NNNN.exr
# (formats otherwise vary), so only those two trailing parts are removed.
base=$(basename "$SRC_FRAMES")
LOCAL_OUT="${base%.*.*}"
if [[ -z "$LOCAL_OUT" || "$LOCAL_OUT" == "$base" ]]; then
  echo "Could not derive LOCAL_OUT from SRC_FRAMES: $SRC_FRAMES" >&2
  exit 1
fi
REMOTE_DEST="/mnt/DELTA/" # mount point for the delta
PY="/mnt/d1/dometools/.domenv/bin/python"
MAKE7TH="/mnt/d1/dometools/make7th.py"
LOG="$HOME/logs/make7th.log"

mkdir -p "$(dirname "$LOG")" "$LOCAL_OUT"   

{
  echo "=== $(date -Is) start ==="
  "$PY" "$MAKE7TH" "$SRC_FRAMES" "$LOCAL_OUT"
  echo "--- conversion done, starting rsync ---"
  rsync -a --partial --info=stats2 "$LOCAL_OUT/" "$REMOTE_DEST"
  echo "=== $(date -Is) done ==="
} >> "$LOG" 2>&1
